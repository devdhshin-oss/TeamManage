rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: artifacts/{appId}/public/data/workspaces
    // Fields:
    //   - id: string, document id mirrored by client
    //   - name: string, required
    //   - description: string, optional
    //   - ownerId: string, required, immutable after create
    //   - ownerEmail: string, optional
    //   - members: list<string>, optional, normalized lowercase emails
    //   - accessKeys: list<string>, optional, values like uid:{uid} or email:{email}
    //
    // Collections: tasks, members, departments, projects
    // Shared field:
    //   - workspaceId: string, required, immutable after create
    //
    // Collection: artifacts/{appId}/public/data/members
    // Additional fields:
    //   - annualLeaveBase: number or empty string, optional, manually assigned annual leave days
    //
    // Collection: artifacts/{appId}/public/data/workspaceAccess
    // Fields:
    //   - id: string, document id mirrored by client
    //   - workspaceId: string, required
    //   - workspaceName: string, optional display label
    //   - email: string, required, normalized lowercase invited account
    //   - ownerId: string, required, workspace owner uid
    //   - createdAt: string, optional date label
    //   - status: string, optional, one of pending/accepted/declined
    //   - legacyAccessId: string, optional, previous encoded invite document id used for migration
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : '';
    }

    function workspacePath(appId, workspaceId) {
      return /databases/$(database)/documents/artifacts/$(appId)/public/data/workspaces/$(workspaceId);
    }

    function workspaceAccessPath(appId, workspaceId, email) {
      return /databases/$(database)/documents/artifacts/$(appId)/public/data/workspaceAccess/$(workspaceId + '_' + email);
    }

    function workspaceAccessDocumentPath(appId, accessId) {
      return /databases/$(database)/documents/artifacts/$(appId)/public/data/workspaceAccess/$(accessId);
    }

    function workspaceExists(appId, workspaceId) {
      return exists(workspacePath(appId, workspaceId));
    }

    function workspaceData(appId, workspaceId) {
      return get(workspacePath(appId, workspaceId)).data;
    }

    function workspaceMembers(appId, workspaceId) {
      return workspaceData(appId, workspaceId).members is list ? workspaceData(appId, workspaceId).members : [];
    }

    function workspaceAccessKeys(data) {
      return data.accessKeys is list ? data.accessKeys : [];
    }

    function hasAcceptedWorkspaceAccess(appId, workspaceId) {
      let accessPath = workspaceAccessPath(appId, workspaceId, userEmail());
      return signedIn() &&
        workspaceId is string &&
        userEmail() != '' &&
        exists(accessPath) &&
        get(accessPath).data.email == userEmail() &&
        get(accessPath).data.workspaceId == workspaceId &&
        get(accessPath).data.status == 'accepted';
    }

    function canCreateCanonicalAccessFromLegacy(appId, accessId) {
      let legacyPath = workspaceAccessDocumentPath(appId, request.resource.data.legacyAccessId);
      return signedIn() &&
        request.resource.data.id == accessId &&
        request.resource.data.id == request.resource.data.workspaceId + '_' + userEmail() &&
        request.resource.data.email == userEmail() &&
        request.resource.data.status == 'accepted' &&
        request.resource.data.legacyAccessId is string &&
        request.resource.data.legacyAccessId != accessId &&
        exists(legacyPath) &&
        get(legacyPath).data.email == userEmail() &&
        get(legacyPath).data.workspaceId == request.resource.data.workspaceId &&
        get(legacyPath).data.ownerId == request.resource.data.ownerId &&
        get(legacyPath).data.status == 'accepted';
    }

    function canReadWorkspace(appId, data) {
      return signedIn() &&
        (
          data.ownerId == request.auth.uid ||
          hasAcceptedWorkspaceAccess(appId, data.id) ||
          userEmail() in (data.members is list ? data.members : []) ||
          ('uid:' + request.auth.uid) in workspaceAccessKeys(data) ||
          ('email:' + userEmail()) in workspaceAccessKeys(data)
        );
    }

    function isWorkspaceMember(appId, workspaceId) {
      return signedIn() &&
        workspaceId is string &&
        workspaceExists(appId, workspaceId) &&
        (
          workspaceData(appId, workspaceId).ownerId == request.auth.uid ||
          hasAcceptedWorkspaceAccess(appId, workspaceId) ||
          userEmail() in workspaceMembers(appId, workspaceId) ||
          ('uid:' + request.auth.uid) in workspaceAccessKeys(workspaceData(appId, workspaceId)) ||
          ('email:' + userEmail()) in workspaceAccessKeys(workspaceData(appId, workspaceId))
        );
    }

    function isWorkspaceOwner(appId, workspaceId) {
      return signedIn() &&
        workspaceId is string &&
        workspaceExists(appId, workspaceId) &&
        workspaceData(appId, workspaceId).ownerId == request.auth.uid;
    }

    function hasOnly(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function hasRequired(data, fields) {
      return data.keys().hasAll(fields);
    }

    function optionalString(data, field, maxLength) {
      return !(field in data) ||
        (data[field] is string && data[field].size() <= maxLength);
    }

    function optionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function optionalList(data, field, maxSize) {
      return !(field in data) || (data[field] is list && data[field].size() <= maxSize);
    }

    function nullableString(data, field, maxLength) {
      return !(field in data) ||
        data[field] == null ||
        (data[field] is string && data[field].size() <= maxLength);
    }

    function validWorkspace(data) {
      return hasOnly(data, ['id', 'name', 'description', 'ownerId', 'ownerEmail', 'members', 'accessKeys']) &&
        hasRequired(data, ['id', 'name', 'ownerId']) &&
        data.id is string &&
        data.id.size() > 0 &&
        data.id.size() <= 80 &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 80 &&
        data.ownerId is string &&
        data.ownerId.size() > 0 &&
        optionalString(data, 'description', 500) &&
        optionalString(data, 'ownerEmail', 254) &&
        optionalList(data, 'members', 200) &&
        optionalList(data, 'accessKeys', 300);
    }

    function validWorkspaceAccess(data) {
      return hasOnly(data, ['id', 'workspaceId', 'workspaceName', 'email', 'ownerId', 'createdAt', 'status', 'legacyAccessId']) &&
        hasRequired(data, ['id', 'workspaceId', 'email', 'ownerId']) &&
        data.id is string &&
        data.id.size() > 0 &&
        data.id.size() <= 220 &&
        data.workspaceId is string &&
        data.workspaceId.size() > 0 &&
        data.workspaceId.size() <= 80 &&
        data.email is string &&
        data.email.size() > 0 &&
        data.email.size() <= 254 &&
        data.ownerId is string &&
        data.ownerId.size() > 0 &&
        optionalString(data, 'workspaceName', 80) &&
        optionalString(data, 'createdAt', 20) &&
        optionalString(data, 'legacyAccessId', 220) &&
        (!(data.keys().hasAny(['status'])) || data.status in ['pending', 'accepted', 'declined']);
    }

    function validTask(data) {
      return hasOnly(data, [
        'id', 'workspaceId', 'title', 'projectId', 'assignee', 'description',
        'status', 'hasIssue', 'issueNote', 'subtasks', 'startDate',
        'targetDate', 'updatedAt'
      ]) &&
        hasRequired(data, ['id', 'workspaceId', 'title', 'status']) &&
        data.id is string &&
        data.workspaceId is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 200 &&
        data.status in ['todo', 'in-progress', 'done'] &&
        optionalString(data, 'projectId', 80) &&
        optionalString(data, 'assignee', 80) &&
        optionalString(data, 'description', 5000) &&
        optionalString(data, 'issueNote', 2000) &&
        optionalString(data, 'startDate', 20) &&
        optionalString(data, 'targetDate', 20) &&
        optionalString(data, 'updatedAt', 20) &&
        optionalBool(data, 'hasIssue') &&
        optionalList(data, 'subtasks', 100);
    }

    function validMember(data) {
      return hasOnly(data, [
        'id', 'workspaceId', 'name', 'rank', 'departmentId', 'role',
        'joinDate', 'promotionDate', 'birthday', 'email', 'phone',
        'annualLeaveBase', 'isAdmin'
      ]) &&
        hasRequired(data, ['id', 'workspaceId', 'name']) &&
        data.id is string &&
        data.workspaceId is string &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 80 &&
        optionalString(data, 'rank', 30) &&
        optionalString(data, 'departmentId', 80) &&
        optionalString(data, 'role', 120) &&
        optionalString(data, 'joinDate', 20) &&
        optionalString(data, 'promotionDate', 20) &&
        optionalString(data, 'birthday', 20) &&
        optionalString(data, 'email', 254) &&
        optionalString(data, 'phone', 50) &&
        optionalBool(data, 'isAdmin') &&
        (!(data.keys().hasAny(['annualLeaveBase'])) ||
          data.annualLeaveBase == '' ||
          data.annualLeaveBase is int ||
          data.annualLeaveBase is float);
    }

    function validDepartment(data) {
      return hasOnly(data, ['id', 'workspaceId', 'name', 'parentId']) &&
        hasRequired(data, ['id', 'workspaceId', 'name']) &&
        data.id is string &&
        data.workspaceId is string &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 80 &&
        nullableString(data, 'parentId', 80);
    }

    function validProject(data) {
      return hasOnly(data, ['id', 'workspaceId', 'name', 'color']) &&
        hasRequired(data, ['id', 'workspaceId', 'name']) &&
        data.id is string &&
        data.workspaceId is string &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 80 &&
        optionalString(data, 'color', 30);
    }

    match /artifacts/{appId}/public/data {
      match /workspaces/{workspaceId} {
        allow read: if signedIn() &&
          canReadWorkspace(appId, resource.data);

        allow create: if signedIn() &&
          workspaceId != 'default' &&
          validWorkspace(request.resource.data) &&
          request.resource.data.id == workspaceId &&
          request.resource.data.ownerId == request.auth.uid;

        allow update: if signedIn() &&
          workspaceId != 'default' &&
          resource.data.ownerId == request.auth.uid &&
          validWorkspace(request.resource.data) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.ownerId == resource.data.ownerId;

        allow delete: if signedIn() &&
          workspaceId != 'default' &&
          resource.data.ownerId == request.auth.uid;
      }

      match /workspaceAccess/{accessId} {
        // 초대받은 본인이 읽기 가능 (단일 조건으로 분리하여 쿼리 시 규칙 평가 오류 방지)
        allow read: if signedIn() && resource.data.email == userEmail();
        
        // 워크스페이스 소유자가 읽기 가능
        allow read: if signedIn() && isWorkspaceOwner(appId, resource.data.workspaceId);
        allow create: if validWorkspaceAccess(request.resource.data) &&
          request.resource.data.id == accessId &&
          request.resource.data.email == request.resource.data.email.lower() &&
          (
            (
              isWorkspaceOwner(appId, request.resource.data.workspaceId) &&
              request.resource.data.ownerId == request.auth.uid
            ) ||
            canCreateCanonicalAccessFromLegacy(appId, accessId)
          );

        // 워크스페이스 소유자: 전체 업데이트 가능
        allow update: if validWorkspaceAccess(request.resource.data) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.workspaceId == resource.data.workspaceId &&
          request.resource.data.email == resource.data.email &&
          isWorkspaceOwner(appId, resource.data.workspaceId) &&
          request.resource.data.ownerId == resource.data.ownerId;

        // 초대받은 본인: status 필드만 변경 가능 (수락/거부)
        allow update: if signedIn() &&
          validWorkspaceAccess(request.resource.data) &&
          resource.data.email == userEmail() &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.workspaceId == resource.data.workspaceId &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status in ['pending', 'accepted', 'declined'];

        allow delete: if isWorkspaceOwner(appId, resource.data.workspaceId);
      }

      match /tasks/{taskId} {
        allow read, delete: if isWorkspaceMember(appId, resource.data.workspaceId);
        allow create: if validTask(request.resource.data) &&
          request.resource.data.id == taskId &&
          isWorkspaceMember(appId, request.resource.data.workspaceId);
        allow update: if validTask(request.resource.data) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.workspaceId == resource.data.workspaceId &&
          isWorkspaceMember(appId, resource.data.workspaceId);
      }

      match /members/{memberId} {
        allow read: if isWorkspaceMember(appId, resource.data.workspaceId);
        allow delete: if isWorkspaceOwner(appId, resource.data.workspaceId);
        allow create: if validMember(request.resource.data) &&
          request.resource.data.id == memberId &&
          isWorkspaceOwner(appId, request.resource.data.workspaceId);
        allow update: if validMember(request.resource.data) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.workspaceId == resource.data.workspaceId &&
          isWorkspaceOwner(appId, resource.data.workspaceId);
      }

      match /departments/{departmentId} {
        allow read: if isWorkspaceMember(appId, resource.data.workspaceId);
        allow delete: if isWorkspaceOwner(appId, resource.data.workspaceId);
        allow create: if validDepartment(request.resource.data) &&
          request.resource.data.id == departmentId &&
          isWorkspaceOwner(appId, request.resource.data.workspaceId);
        allow update: if validDepartment(request.resource.data) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.workspaceId == resource.data.workspaceId &&
          isWorkspaceOwner(appId, resource.data.workspaceId);
      }

      match /projects/{projectId} {
        allow read, delete: if isWorkspaceMember(appId, resource.data.workspaceId);
        allow create: if validProject(request.resource.data) &&
          request.resource.data.id == projectId &&
          isWorkspaceMember(appId, request.resource.data.workspaceId);
        allow update: if validProject(request.resource.data) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.workspaceId == resource.data.workspaceId &&
          isWorkspaceMember(appId, resource.data.workspaceId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
